#!/usr/bin/env bash
set -euo pipefail

print_help() {
cat << EOF
Usage:
  p_tree [DIRECTORY]

Description:
  Display a project tree while ignoring common build artifacts.

Ignored paths:
  target
  .git
  node_modules
  Cargo.lock
  hidden files

Examples:
  p_tree
  p_tree ./project
EOF
}

require_cmd() {
command -v "$1" >/dev/null 2>&1 || {
echo "Error: '$1' is required but not installed."
exit 1
}
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
print_help
exit 0
fi

require_cmd tree

TARGET="${1:-.}"

IGNORE_LIST=(
"target"
".git"
"node_modules"
"Cargo.lock"
".*"
)

IGNORE_PATTERN=$(IFS="|"; echo "${IGNORE_LIST[*]}")

tree -a -I "$IGNORE_PATTERN" "$TARGET"
